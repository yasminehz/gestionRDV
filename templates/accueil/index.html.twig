{% extends 'base.html.twig' %}

{% block title %}Accueil - gestionRDV{% endblock %}

{% block body %}
<div class="container" style="max-width: 1000px; padding-top: 32px; padding-bottom: 48px;">

  {% if app.user %}
    {# En-tete de bienvenue #}
    <div class="welcome-card">
      <div class="welcome-avatar">
        {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
      </div>
      <div class="welcome-content">
        <h1>Bonjour, {{ app.user.prenom }} !</h1>
        <p class="welcome-email">{{ app.user.email }}</p>
        <div class="welcome-role">
          {% if is_granted('ROLE_MEDECIN') %}
            <span class="role-badge role-medecin">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
              </svg>
              Medecin
            </span>
          {% elseif is_granted('ROLE_PATIENT') %}
            <span class="role-badge role-patient">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
              Patient
            </span>
          {% elseif is_granted('ROLE_ASSISTANT') %}
            <span class="role-badge role-assistant">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
              Assistant
            </span>
          {% endif %}
        </div>
      </div>
    </div>

    {# Actions rapides #}
    <div class="quick-actions">
      {% if is_granted('ROLE_PATIENT') %}
        <a href="{{ path('app_rendez_vous_new') }}" class="action-card action-primary">
          <div class="action-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
              <line x1="12" y1="14" x2="12" y2="18"></line>
              <line x1="10" y1="16" x2="14" y2="16"></line>
            </svg>
          </div>
          <div class="action-content">
            <h3>Prendre un RDV</h3>
            <p>Demandez un rendez-vous aupres d'un medecin</p>
          </div>
          <div class="action-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </div>
        </a>

        <a href="{{ path('app_mes_rendez_vous') }}" class="action-card">
          <div class="action-icon action-icon-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
          </div>
          <div class="action-content">
            <h3>Mes rendez-vous</h3>
            <p>Consultez l'historique de vos rendez-vous</p>
          </div>
          <div class="action-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </div>
        </a>

      {% elseif is_granted('ROLE_MEDECIN') %}
        <a href="{{ path('disponibilite_index') }}" class="action-card action-primary">
          <div class="action-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <div class="action-content">
            <h3>Mes disponibilites</h3>
            <p>Gerez votre planning hebdomadaire</p>
          </div>
          <div class="action-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </div>
        </a>

        <a href="{{ path('app_mes_rendez_vous') }}" class="action-card">
          <div class="action-icon action-icon-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
          </div>
          <div class="action-content">
            <h3>Mes rendez-vous</h3>
            <p>Consultez vos rendez-vous a venir</p>
          </div>
          <div class="action-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </div>
        </a>

        <a href="{{ path('app_medecin_assistants', {'id': app.user.id}) }}" class="action-card">
          <div class="action-icon action-icon-tertiary">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <div class="action-content">
            <h3>Mes assistants</h3>
            <p>Gerez votre equipe d'assistants</p>
          </div>
          <div class="action-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </div>
        </a>

      {% elseif is_granted('ROLE_ASSISTANT') %}
        <a href="{{ path('app_mes_rendez_vous') }}" class="action-card action-primary">
          <div class="action-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
          </div>
          <div class="action-content">
            <h3>Gerer les RDV</h3>
            <p>Consultez et gerez les rendez-vous du medecin</p>
          </div>
          <div class="action-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </div>
        </a>
      {% endif %}
    </div>

  {% else %}
    {# Page d'accueil non connecte #}
    <div class="hero-section">
      <div class="hero-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
      </div>
      <h1>Bienvenue sur gestionRDV</h1>
      <p class="hero-subtitle">Gerez vos rendez-vous medicaux simplement et facilement</p>
      <a href="{{ path('app_login') }}" class="btn btn-primary btn-lg">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
          <polyline points="10 17 15 12 10 7"></polyline>
          <line x1="15" y1="12" x2="3" y2="12"></line>
        </svg>
        Se connecter
      </a>
    </div>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon feature-icon-medecin">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
          </svg>
        </div>
        <h3>Medecin</h3>
        <p>Gerez vos rendez-vous et votre equipe d'assistants</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon feature-icon-patient">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </div>
        <h3>Patient</h3>
        <p>Demandez et suivez vos rendez-vous medicaux</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon feature-icon-assistant">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
        </div>
        <h3>Assistant</h3>
        <p>Aidez a la gestion des rendez-vous de votre medecin</p>
      </div>
    </div>
  {% endif %}
</div>

<style>
/* ===== Welcome Card Premium ===== */
.welcome-card {
  display: flex;
  align-items: center;
  gap: 28px;
  padding: 36px 40px;
  background: linear-gradient(135deg, var(--card) 0%, var(--bg-light) 100%);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-light);
  border-radius: 24px;
  margin-bottom: 32px;
  box-shadow: var(--shadow-lg);
  position: relative;
  overflow: hidden;
  animation: slideUp 0.5s ease-out;
}

.welcome-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -10%;
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(99, 102, 241, 0.06) 0%, transparent 60%);
  pointer-events: none;
  opacity: 0.8;
}

.welcome-avatar {
  width: 80px;
  height: 80px;
  background: linear-gradient(135deg, var(--primary) 0%, #a855f7 50%, var(--accent) 100%);
  background-size: 200% 200%;
  animation: gradientShift 3s ease-in-out infinite;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.75rem;
  font-weight: 700;
  flex-shrink: 0;
  box-shadow: 
    0 8px 24px -4px rgba(99, 102, 241, 0.4),
    inset 0 2px 4px rgba(255, 255, 255, 0.3);
  position: relative;
}

.welcome-avatar::after {
  content: '';
  position: absolute;
  inset: -3px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--accent));
  z-index: -1;
  opacity: 0.3;
  filter: blur(8px);
}

.welcome-content h1 {
  margin: 0 0 6px;
  font-size: 1.875rem;
  font-weight: 800;
  background: linear-gradient(135deg, var(--text) 0%, #475569 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.welcome-email {
  margin: 0 0 14px;
  color: var(--text-muted);
  font-size: 0.95rem;
  display: flex;
  align-items: center;
  gap: 6px;
}

.welcome-email::before {
  content: '✉️';
  font-size: 0.85rem;
}

.welcome-role {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.role-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  border-radius: 50px;
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 0.02em;
  text-transform: uppercase;
  transition: all 0.2s ease;
}

.role-badge:hover {
  transform: translateY(-2px);
}

.role-medecin {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.15) 0%, rgba(16, 185, 129, 0.08) 100%);
  color: #059669;
  box-shadow: 0 2px 8px rgba(16, 185, 129, 0.2);
}

.role-patient {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.15) 0%, rgba(168, 85, 247, 0.08) 100%);
  color: var(--primary);
  box-shadow: 0 2px 8px rgba(99, 102, 241, 0.2);
}

.role-assistant {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.15) 0%, rgba(234, 88, 12, 0.08) 100%);
  color: #d97706;
  box-shadow: 0 2px 8px rgba(245, 158, 11, 0.2);
}

/* ===== Quick Actions Premium ===== */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 20px;
}

.action-card {
  display: flex;
  align-items: center;
  gap: 18px;
  padding: 24px 28px;
  background: linear-gradient(135deg, var(--card) 0%, var(--bg-light) 100%);
  backdrop-filter: blur(10px);
  border: 1px solid var(--border-light);
  border-radius: 20px;
  text-decoration: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: var(--shadow-md);
  position: relative;
  overflow: hidden;
}

.action-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(99, 102, 241, 0.03) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.action-card:hover {
  transform: translateY(-6px) scale(1.01);
  box-shadow: var(--shadow-xl);
  border-color: var(--primary-100);
}

.action-card:hover::before {
  opacity: 1;
}

.action-card.action-primary {
  background: linear-gradient(135deg, var(--primary) 0%, #7c3aed 50%, var(--accent) 100%);
  background-size: 200% 200%;
  animation: gradientShift 4s ease-in-out infinite;
  border: none;
  box-shadow: 
    0 8px 32px -4px rgba(99, 102, 241, 0.4),
    inset 0 1px 0 rgba(255, 255, 255, 0.2);
}

.action-card.action-primary:hover {
  box-shadow: 
    0 16px 48px -8px rgba(99, 102, 241, 0.5),
    inset 0 1px 0 rgba(255, 255, 255, 0.2);
}

.action-card.action-primary .action-content h3,
.action-card.action-primary .action-content p,
.action-card.action-primary .action-arrow {
  color: white;
}

.action-card.action-primary .action-content p {
  opacity: 0.9;
}

.action-icon {
  width: 60px;
  height: 60px;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(8px);
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  flex-shrink: 0;
  transition: all 0.3s ease;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.3);
}

.action-card:hover .action-icon {
  transform: scale(1.08) rotate(-3deg);
}

.action-icon-secondary {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.15) 0%, rgba(168, 85, 247, 0.1) 100%);
  color: var(--primary);
  box-shadow: 
    0 4px 12px rgba(99, 102, 241, 0.15),
    inset 0 1px 0 rgba(255, 255, 255, 0.8);
}

.action-icon-tertiary {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.15) 0%, rgba(234, 88, 12, 0.1) 100%);
  color: #d97706;
  box-shadow: 
    0 4px 12px rgba(245, 158, 11, 0.15),
    inset 0 1px 0 rgba(255, 255, 255, 0.8);
}

.action-content {
  flex: 1;
  min-width: 0;
}

.action-content h3 {
  margin: 0 0 6px;
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--text);
  transition: color 0.2s ease;
}

.action-content p {
  margin: 0;
  font-size: 0.9rem;
  color: var(--text-muted);
  line-height: 1.4;
}

.action-arrow {
  color: var(--text-muted);
  flex-shrink: 0;
  opacity: 0;
  transform: translateX(-12px);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.action-card:hover .action-arrow {
  opacity: 1;
  transform: translateX(0);
}

.action-card.action-primary .action-arrow {
  opacity: 0.7;
}

.action-card.action-primary:hover .action-arrow {
  opacity: 1;
}

/* ===== Hero Section Premium ===== */
.hero-section {
  text-align: center;
  padding: 80px 48px;
  background: linear-gradient(180deg, var(--card) 0%, var(--bg-secondary) 100%);
  backdrop-filter: blur(20px);
  border: 1px solid var(--border-light);
  border-radius: 32px;
  margin-bottom: 40px;
  box-shadow: var(--shadow-lg);
  position: relative;
  overflow: hidden;
  animation: fadeIn 0.6s ease-out;
}

.hero-section::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle at 30% 20%, rgba(99, 102, 241, 0.08) 0%, transparent 50%),
              radial-gradient(circle at 70% 80%, rgba(13, 148, 136, 0.06) 0%, transparent 50%);
  pointer-events: none;
  animation: float 20s ease-in-out infinite;
}

.hero-icon {
  width: 110px;
  height: 110px;
  margin: 0 auto 32px;
  background: linear-gradient(135deg, var(--primary) 0%, #7c3aed 50%, var(--accent) 100%);
  background-size: 200% 200%;
  animation: gradientShift 4s ease-in-out infinite;
  border-radius: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  box-shadow: 
    0 16px 48px -8px rgba(99, 102, 241, 0.4),
    inset 0 2px 4px rgba(255, 255, 255, 0.3);
  position: relative;
  transform: rotate(-3deg);
  transition: transform 0.4s ease;
}

.hero-icon:hover {
  transform: rotate(0deg) scale(1.05);
}

.hero-icon::after {
  content: '';
  position: absolute;
  inset: -6px;
  border-radius: 32px;
  background: linear-gradient(135deg, var(--primary), var(--accent));
  z-index: -1;
  opacity: 0.2;
  filter: blur(16px);
}

.hero-section h1 {
  margin: 0 0 16px;
  font-size: 2.5rem;
  font-weight: 800;
  background: linear-gradient(135deg, var(--text) 0%, #475569 50%, var(--primary) 100%);
  background-size: 200% 200%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: gradientShift 5s ease-in-out infinite;
  position: relative;
}

.hero-subtitle {
  margin: 0 0 40px;
  font-size: 1.2rem;
  color: var(--text-muted);
  max-width: 500px;
  margin-left: auto;
  margin-right: auto;
  line-height: 1.6;
}

.btn-lg {
  padding: 18px 40px;
  font-size: 1.1rem;
  font-weight: 600;
  border-radius: 16px;
  box-shadow: 
    0 8px 24px -4px rgba(99, 102, 241, 0.4),
    inset 0 1px 0 rgba(255, 255, 255, 0.2);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-lg:hover {
  transform: translateY(-3px);
  box-shadow: 
    0 16px 40px -8px rgba(99, 102, 241, 0.5),
    inset 0 1px 0 rgba(255, 255, 255, 0.2);
}

/* ===== Features Grid Premium ===== */
.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
}

.feature-card {
  padding: 36px 32px;
  background: linear-gradient(135deg, var(--card) 0%, var(--bg-light) 100%);
  backdrop-filter: blur(10px);
  border: 1px solid var(--border-light);
  border-radius: 24px;
  text-align: center;
  box-shadow: var(--shadow-md);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.feature-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--primary), var(--accent));
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.4s ease;
}

.feature-card:hover {
  transform: translateY(-8px);
  box-shadow: var(--shadow-xl);
  border-color: var(--primary-100);
}

.feature-card:hover::before {
  transform: scaleX(1);
}

.feature-icon {
  width: 80px;
  height: 80px;
  margin: 0 auto 24px;
  border-radius: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.4s ease;
  position: relative;
}

.feature-card:hover .feature-icon {
  transform: scale(1.1) rotate(-5deg);
}

.feature-icon::after {
  content: '';
  position: absolute;
  inset: -4px;
  border-radius: 26px;
  opacity: 0.3;
  filter: blur(12px);
  z-index: -1;
  transition: opacity 0.3s ease;
}

.feature-card:hover .feature-icon::after {
  opacity: 0.5;
}

.feature-icon-medecin {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.18) 0%, rgba(16, 185, 129, 0.08) 100%);
  color: #059669;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
}

.feature-icon-medecin::after {
  background: #10b981;
}

.feature-icon-patient {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.18) 0%, rgba(168, 85, 247, 0.08) 100%);
  color: var(--primary);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
}

.feature-icon-patient::after {
  background: var(--primary);
}

.feature-icon-assistant {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.18) 0%, rgba(234, 88, 12, 0.08) 100%);
  color: #d97706;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
}

.feature-icon-assistant::after {
  background: #f59e0b;
}

.feature-card h3 {
  margin: 0 0 10px;
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--text);
}

.feature-card p {
  margin: 0;
  font-size: 0.95rem;
  color: var(--text-muted);
  line-height: 1.6;
}

/* ===== Animations ===== */
@keyframes gradientShift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes float {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(10px, -10px) rotate(1deg); }
  66% { transform: translate(-5px, 5px) rotate(-1deg); }
}

/* ===== Responsive ===== */
@media (max-width: 768px) {
  .welcome-card {
    flex-direction: column;
    text-align: center;
    padding: 28px 24px;
    gap: 20px;
  }

  .welcome-avatar {
    width: 72px;
    height: 72px;
    font-size: 1.5rem;
  }

  .welcome-content h1 {
    font-size: 1.5rem;
  }

  .welcome-email {
    justify-content: center;
  }

  .welcome-role {
    justify-content: center;
  }

  .quick-actions {
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .action-card {
    padding: 20px 24px;
  }

  .action-icon {
    width: 52px;
    height: 52px;
  }

  .hero-section {
    padding: 50px 28px;
    border-radius: 24px;
  }

  .hero-icon {
    width: 88px;
    height: 88px;
    border-radius: 22px;
  }

  .hero-section h1 {
    font-size: 1.75rem;
  }

  .hero-subtitle {
    font-size: 1.05rem;
    margin-bottom: 32px;
  }

  .btn-lg {
    padding: 16px 32px;
    font-size: 1rem;
  }

  .features-grid {
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .feature-card {
    padding: 28px 24px;
  }

  .feature-icon {
    width: 68px;
    height: 68px;
  }
}

