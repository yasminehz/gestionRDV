{% extends 'base.html.twig' %}

{% block title %}Accueil - gestionRDV{% endblock %}

{% block body %}
<div class="container">
  <div class="text-center mb-4">
    <h1>Bienvenue sur gestionRDV</h1>
    <p class="text-muted">Gérez vos rendez-vous médicaux simplement et facilement</p>
  </div>

  {% if app.user %}
    <div class="card mb-4">
      <div class="mb-3">
        <h2 class="mb-2">Bienvenue, <span class="text-primary">{{ app.user.prenom }} {{ app.user.nom }}</span>!</h2>
        <p class="text-muted mb-0">Vous êtes connecté avec l'adresse email : <strong>{{ app.user.email }}</strong></p>
      </div>
      
      <div style="display: flex; gap: 12px; align-items: center; margin-top: 16px;">
        {% if is_granted('ROLE_MEDECIN') %}
          <span class="badge bg-primary">Médecin</span>
        {% elseif is_granted('ROLE_PATIENT') %}
          <span class="badge bg-info">Patient</span>
        {% elseif is_granted('ROLE_ASSISTANT') %}
          <span class="badge bg-warning">Assistant</span>
        {% endif %}
      </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-top: 32px;">
      
      {% if is_granted('ROLE_PATIENT') %}
        <div class="card">
          <h3 style="margin-top: 0;">Prendre un RDV</h3>
          <p class="text-muted">Demandez un rendez-vous auprès d'un médecin</p>
          <a href="{{ path('app_rendez_vous_new') }}" class="btn btn-primary" style="width: 100%; margin-top: 12px;">Nouveau RDV</a>
        </div>

        <div class="card">
          <h3 style="margin-top: 0;">Mes RDV</h3>
          <p class="text-muted">Consultez l'historique de vos rendez-vous</p>
          <a href="{{ path('app_mes_rendez_vous') }}" class="btn btn-outline" style="width: 100%; margin-top: 12px;">Voir mes RDV</a>
        </div>

      {% elseif is_granted('ROLE_MEDECIN') %}
        <div class="card">
          <h3 style="margin-top: 0;">Mes indisponibilités</h3>
          <p class="text-muted">Gérez vos créneaux indisponibles</p>
          <a href="{{ path('indisponibilite_index') }}" class="btn btn-outline" style="width: 100%; margin-top: 12px;">Gérer mes indisponibilités</a>
          <a href="{{ path('app_mes_rendez_vous') }}  " class="btn btn-outline" style="width: 100%; margin-top: 12px;">Voir mes RDV</a>
        </div>

        <div class="card">
          <h3 style="margin-top: 0;">Mes assistants</h3>
          <p class="text-muted">Gérez votre équipe d'assistants</p>
          <a href="{{ path('app_medecin_assistants', {'id': app.user.id}) }}" class="btn btn-outline-primary" style="width: 100%; margin-top: 12px;">Voir les assistants</a>
        </div>

      {% elseif is_granted('ROLE_ASSISTANT') %}
        <div class="card">
          <h3 style="margin-top: 0;">RDV du médecin</h3>
          <p class="text-muted">Consultez l'agenda de votre médecin</p>
          <a href="{{ path('app_assistant_rendezvous', {'id': app.user.id}) }}" class="btn btn-primary" style="width: 100%; margin-top: 12px;">Voir l'agenda</a>
        </div>

        {# Recherche transverse : permet à l'assistant de retrouver tous les patients
           ayant reçu un médicament donné, indépendamment des dates de RDV. #}
        <div class="card">
          <h3 style="margin-top: 0;">Patients par médicament</h3>
          <p class="text-muted">Retrouvez les patients à qui un médicament a été prescrit</p>
          <a href="{{ path('app_medicament_patients') }}" class="btn btn-outline-primary" style="width: 100%; margin-top: 12px;">Rechercher</a>
        </div>
        {#}
        <div class="card">
          <h3 style="margin-top: 0;">Rendez‑vous</h3>
          <p class="text-muted">Gérez les rendez‑vous et les demandes associées</p>
          <a href="" class="btn btn-outline-primary" style="width: 100%; margin-top: 12px;">Voir les RDV</a>
        </div>#}

      {% endif %}
    </div>

  {% else %}
    <div class="card mb-4">
      <div class="text-center">
        <p class="mb-3" style="font-size: 1.2rem;">Vous n'êtes pas connecté</p>
        <p class="text-muted mb-4">Connectez-vous pour accéder à votre espace personnel</p>
        <a href="{{ path('app_login') }}" class="btn btn-primary btn-lg">Se connecter</a>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-top: 32px;">
      <div class="card">
        <h3 style="margin-top: 0;">👨‍⚕️ Médecin</h3>
        <p class="text-muted">Gérez vos rendez-vous et votre équipe d'assistants</p>
      </div>
      <div class="card">
        <h3 style="margin-top: 0;">🤒 Patient</h3>
        <p class="text-muted">Demandez et suivez vos rendez-vous médicaux</p>
      </div>
      <div class="card">
        <h3 style="margin-top: 0;">👥 Assistant</h3>
        <p class="text-muted">Aidez à la gestion des rendez-vous de votre médecin</p>
      </div>
    </div>
  {% endif %}
</div>
{% endblock %}
