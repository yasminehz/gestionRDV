{% extends 'base.html.twig' %}

{% block title %}Prescription - RDV du {{ rendezVous.debut|date('d/m/Y') }}{% endblock %}

{% block body %}
<div class="container content-wrapper">
    <main>
        {# ====== Bandeau d'info du RDV concerné ====== #}
        <h1 class="mb-4">Prescription</h1>

        <div class="card mb-4">
            <p>
                <strong>Patient :</strong>
                {{ rendezVous.patient.prenom }} {{ rendezVous.patient.nom }}
            </p>
            <p>
                <strong>Date du rendez-vous :</strong>
                {{ rendezVous.debut|date('d/m/Y') }}
                ({{ rendezVous.debut|date('H:i') }} - {{ rendezVous.fin|date('H:i') }})
            </p>
            <p>
                <strong>État :</strong>
                <span class="badge
                    {% if rendezVous.etat.libelle == 'demandé' %}badge-info{% endif %}
                    {% if rendezVous.etat.libelle == 'confirmé' %}badge-success{% endif %}
                    {% if rendezVous.etat.libelle == 'annulé' %}badge-danger{% endif %}
                    {% if rendezVous.etat.libelle == 'refusé' %}badge-danger{% endif %}
                ">
                    {{ rendezVous.etat.libelle|capitalize }}
                </span>
            </p>
        </div>

        {# ====== Récapitulatif des indications déjà saisies ======
           Permet au médecin de vérifier ce qu'il a déjà prescrit avant
           d'enchaîner une nouvelle saisie. #}
        <h2>Indications déjà prescrites</h2>
        {% if indications is empty %}
            <div class="alert alert-info">
                Aucune indication n'a encore été saisie pour ce rendez-vous.
            </div>
        {% else %}
            <div class="card mb-4">
                <table style="width:100%; border-collapse: collapse;">
                    <thead>
                        <tr style="text-align:left; border-bottom:1px solid var(--border-light);">
                            <th>Médicament</th>
                            <th>Quantité / prise</th>
                            <th>Prises / jour</th>
                            <th>Durée (jours)</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for ind in indications %}
                            <tr style="border-bottom:1px solid var(--border-light);">
                                <td>{{ ind.medicament.libelle }}</td>
                                <td>{{ ind.quantite }}</td>
                                <td>{{ ind.nbPriseParJour }}</td>
                                <td>{{ ind.duree }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}

        {# ====== Formulaire de saisie d'une nouvelle indication ====== #}
        <h2>Ajouter une indication</h2>
        <div class="card">
            {{ form_start(form) }}
                {{ form_row(form.medicament) }}
                {{ form_row(form.quantite) }}
                {{ form_row(form.nbPriseParJour) }}
                {{ form_row(form.duree) }}

                <div style="margin-top: 1rem;">
                    {# Bouton de soumission : redirige sur la même page pour permettre
                       l'ajout d'une indication supplémentaire (autre médicament) #}
                    <button type="submit" class="btn btn-primary">Enregistrer et continuer</button>
                    <a href="{{ path('app_mes_rendez_vous') }}" class="btn btn-secondary">
                        Terminer
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </main>
</div>
{% endblock %}
