{% extends 'base.html.twig' %}

{% block title %}Modifier le rendez-vous{% endblock %}

{% block body %}
<div class="container content-wrapper" style="max-width: 900px;">
    {{ include('components/breadcrumb.html.twig', {
        items: [
            {label: 'Accueil', href: path('homepage')},
            {label: 'Mes rendez-vous', href: path('app_mes_rendez_vous')},
            {label: 'Modifier'}
        ]
    }) }}

    <h1 style="margin-bottom: 24px;">Modifier le rendez-vous</h1>

    <div class="alert alert-info" style="margin-bottom: 24px;">
        <strong>Information importante</strong>
        Modifier un rendez-vous implique une nouvelle demande de confirmation. L'etat passera a "demande" en attente de confirmation.
    </div>

    <div class="card current-rdv" style="margin-bottom: 24px; padding: 20px;">
        <h2 style="margin-top: 0; font-size: 1.1rem; color: var(--muted);">Rendez-vous actuel</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 16px; margin-top: 12px;">
            <div>
                <strong>Date</strong><br>
                {{ rendez_vou.debut|date('d/m/Y') }}
            </div>
            <div>
                <strong>Horaire</strong><br>
                {{ rendez_vou.debut|date('H:i') }} - {{ rendez_vou.fin|date('H:i') }}
            </div>
            <div>
                <strong>Medecin</strong><br>
                Dr {{ rendez_vou.medecin.prenom }} {{ rendez_vou.medecin.nom }}
            </div>
            <div>
                <strong>Etat</strong><br>
                {{ rendez_vou.etat.libelle|capitalize }}
            </div>
        </div>
    </div>

    <div class="card" style="padding: 20px; margin-bottom: 24px;">
        <h3 style="margin-top: 0; margin-bottom: 16px;">Choisir un nouveau creneau</h3>
        <form method="get" style="display: flex; gap: 16px; align-items: flex-end; flex-wrap: wrap;">
            <div style="flex: 1; min-width: 200px;">
                <label for="medecin" style="display: block; font-weight: 600; margin-bottom: 8px;">Filtrer par medecin :</label>
                <select name="medecin" id="medecin" class="form-control" style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid var(--border-light);">
                    <option value="">-- Tous les medecins --</option>
                    {% for m in medecins %}
                        <option value="{{ m.id }}" {{ medecinSelectionne and medecinSelectionne.id == m.id ? 'selected' : '' }}>
                            Dr {{ m.prenom }} {{ m.nom }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <button type="submit" class="btn btn-secondary">Filtrer</button>
            {% if medecinSelectionne %}
                <a href="{{ path('app_mes_rendez_vous_edit', {id: rendez_vou.id}) }}" class="btn btn-outline">Voir tous</a>
            {% endif %}
        </form>
    </div>

    {% if creneaux is empty %}
        <div class="alert alert-warning">
            <strong>Aucun creneau disponible</strong>
            {% if medecinSelectionne %}
                <p>Le Dr {{ medecinSelectionne.prenom }} {{ medecinSelectionne.nom }} n'a pas de creneaux disponibles dans les prochains jours.</p>
                <p><a href="{{ path('app_mes_rendez_vous_edit', {id: rendez_vou.id}) }}">Voir les creneaux de tous les medecins</a></p>
            {% else %}
                <p>Aucun medecin n'a de disponibilites dans les prochains jours.</p>
            {% endif %}
        </div>
    {% else %}
        <p class="text-meta" style="margin-bottom: 16px;">
            {{ creneaux|length }} creneau(x) disponible(s). Cliquez sur un creneau pour modifier votre rendez-vous.
        </p>

        <div class="creneaux-container">
            {% set currentDate = null %}

            {% for creneau in creneaux %}
                {% if creneau.date != currentDate %}
                    {% set currentDate = creneau.date %}
                    <div class="date-header">
                        <div class="date-header-content">
                            <span class="date-jour">{{ creneau.datetime|date('l') }}</span>
                            <span class="date-complet">{{ creneau.datetime|date('j F Y') }}</span>
                        </div>
                    </div>
                {% endif %}

                <form method="post" class="creneau-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('choix_creneau') }}">
                    <input type="hidden" name="creneau" value="1">
                    <input type="hidden" name="medecin" value="{{ creneau.medecin.id }}">
                    <input type="hidden" name="date" value="{{ creneau.date }}">
                    <input type="hidden" name="heure" value="{{ creneau.heure }}">
                    <input type="hidden" name="duree" value="{{ creneau.duree }}">

                    <button type="submit" class="creneau-btn">
                        <div class="creneau-heure">{{ creneau.heure }}</div>
                        <div class="creneau-info">
                            <span class="creneau-medecin">Dr {{ creneau.medecin.prenom }} {{ creneau.medecin.nom }}</span>
                            <span class="creneau-duree">{{ creneau.duree }} min</span>
                        </div>
                    </button>
                </form>
            {% endfor %}
        </div>
    {% endif %}

    <div style="margin-top: 32px;">
        <a href="{{ path('app_mes_rendez_vous') }}" class="btn btn-secondary">Annuler et retourner a mes rendez-vous</a>
    </div>
</div>

<style>
.creneaux-container {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.date-header {
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    color: white;
    padding: 16px 20px;
    border-radius: 8px;
    margin-top: 16px;
    margin-bottom: 8px;
}

.date-header:first-child {
    margin-top: 0;
}

.date-header-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.date-jour {
    font-size: 1.2rem;
    font-weight: 600;
    text-transform: capitalize;
}

.date-complet {
    font-size: 0.9rem;
    opacity: 0.9;
}

.creneau-form {
    display: block;
}

.creneau-btn {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    background: white;
    border: 2px solid var(--border-light);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: left;
}

.creneau-btn:hover {
    border-color: var(--primary);
    background: var(--bg);
    transform: translateX(4px);
}

.creneau-heure {
    font-size: 1.4rem;
    font-weight: 700;
    color: #bfd9ff;
    min-width: 70px;
}

.creneau-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
}

.creneau-medecin {
    font-weight: 500;
    color: var(--text);
}

.creneau-duree {
    font-size: 0.85rem;
    color: var(--muted);
}

.btn-outline {
    background: transparent;
    border: 2px solid var(--border-light);
    color: var(--text);
    padding: 10px 20px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-block;
}

.btn-outline:hover {
    border-color: var(--primary);
    color: var(--primary);
}

.current-rdv {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
}

[data-theme="dark"] .current-rdv {
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    border-color: #334155;
}

[data-theme="dark"] .current-rdv h2 {
    color: #94a3b8;
}

[data-theme="dark"] .current-rdv strong {
    color: #cbd5e1;
}

[data-theme="dark"] .creneau-btn {
    background: #1e293b;
    border-color: #334155;
}

[data-theme="dark"] .creneau-btn:hover {
    background: #0f172a;
    border-color: #818cf8;
}

[data-theme="dark"] .creneau-heure {
    color: #818cf8;
}

[data-theme="dark"] .creneau-medecin {
    color: #f1f5f9;
}

[data-theme="dark"] .creneau-duree {
    color: #94a3b8;
}

[data-theme="dark"] .btn-outline {
    border-color: #334155;
    color: #cbd5e1;
}

[data-theme="dark"] .btn-outline:hover {
    border-color: #818cf8;
    color: #818cf8;
}

[data-theme="dark"] .form-control {
    background: #0f172a;
    border-color: #334155;
    color: #f1f5f9;
}

[data-theme="dark"] .form-control option {
    background: #1e293b;
    color: #f1f5f9;
}
</style>
{% endblock %}
