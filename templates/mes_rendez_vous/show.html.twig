{% extends 'base.html.twig' %}

{% block title %}Detail du rendez-vous{% endblock %}

{% block body %}
<div class="container" style="max-width: 800px; padding-top: 32px; padding-bottom: 48px;">
    {# Breadcrumb #}
    <nav class="breadcrumb-nav" aria-label="Fil d'ariane">
        <a href="{{ path('homepage') }}" class="breadcrumb-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
            Accueil
        </a>
        <span class="breadcrumb-sep">/</span>
        <a href="{{ path('app_mes_rendez_vous') }}" class="breadcrumb-link">Mes rendez-vous</a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">Detail</span>
    </nav>

    {# Tableaux de traduction #}
    {% set moisFr = {'Jan': 'JAN', 'Feb': 'FÉV', 'Mar': 'MAR', 'Apr': 'AVR', 'May': 'MAI', 'Jun': 'JUIN', 'Jul': 'JUIL', 'Aug': 'AOÛT', 'Sep': 'SEP', 'Oct': 'OCT', 'Nov': 'NOV', 'Dec': 'DÉC'} %}
    {% set joursFr = {'Monday': 'Lundi', 'Tuesday': 'Mardi', 'Wednesday': 'Mercredi', 'Thursday': 'Jeudi', 'Friday': 'Vendredi', 'Saturday': 'Samedi', 'Sunday': 'Dimanche'} %}
    {% set moisLongFr = {'January': 'janvier', 'February': 'février', 'March': 'mars', 'April': 'avril', 'May': 'mai', 'June': 'juin', 'July': 'juillet', 'August': 'août', 'September': 'septembre', 'October': 'octobre', 'November': 'novembre', 'December': 'décembre'} %}

    {# En-tete avec statut #}
    <div class="detail-header">
        <div class="detail-header-content">
            <div class="detail-date-badge">
                <span class="detail-date-day">{{ rendez_vou.debut|date('d') }}</span>
                <span class="detail-date-month">{{ moisFr[rendez_vou.debut|date('M')] }}</span>
            </div>
            <div class="detail-title">
                <h1>Rendez-vous du {{ rendez_vou.debut|date('d/m/Y') }}</h1>
                <p class="detail-time">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                    {{ rendez_vou.debut|date('H:i') }} - {{ rendez_vou.fin|date('H:i') }}
                </p>
            </div>
        </div>
        <span class="status-badge-lg status-{{ rendez_vou.etat.libelle == 'confirmé' ? 'success' : (rendez_vou.etat.libelle in ['annulé', 'refusé'] ? 'danger' : (rendez_vou.etat.libelle == 'réalisé' ? 'info' : 'pending')) }}">
            {% if rendez_vou.etat.libelle == 'confirmé' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
            {% elseif rendez_vou.etat.libelle in ['annulé', 'refusé'] %}
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            {% elseif rendez_vou.etat.libelle == 'réalisé' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
            {% else %}
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
            {% endif %}
            {{ rendez_vou.etat.libelle|capitalize }}
        </span>
    </div>

    {# Informations detaillees #}
    <div class="detail-card">
        <h2 class="detail-section-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="16" x2="12" y2="12"></line>
                <line x1="12" y1="8" x2="12.01" y2="8"></line>
            </svg>
            Informations
        </h2>

        <div class="detail-grid">
            <div class="detail-item">
                <div class="detail-item-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                </div>
                <div class="detail-item-content">
                    <span class="detail-item-label">Date</span>
                    <span class="detail-item-value">{{ joursFr[rendez_vou.debut|date('l')] }} {{ rendez_vou.debut|date('d') }} {{ moisLongFr[rendez_vou.debut|date('F')] }} {{ rendez_vou.debut|date('Y') }}</span>
                </div>
            </div>

            <div class="detail-item">
                <div class="detail-item-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                </div>
                <div class="detail-item-content">
                    <span class="detail-item-label">Horaire</span>
                    <span class="detail-item-value">{{ rendez_vou.debut|date('H:i') }} - {{ rendez_vou.fin|date('H:i') }}</span>
                </div>
            </div>

            <div class="detail-item">
                <div class="detail-item-icon detail-item-icon-medecin">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
                    </svg>
                </div>
                <div class="detail-item-content">
                    <span class="detail-item-label">Medecin</span>
                    <span class="detail-item-value">Dr {{ rendez_vou.medecin.nom }} {{ rendez_vou.medecin.prenom }}</span>
                </div>
            </div>

            <div class="detail-item">
                <div class="detail-item-icon detail-item-icon-patient">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                </div>
                <div class="detail-item-content">
                    <span class="detail-item-label">Patient</span>
                    <span class="detail-item-value">{{ rendez_vou.patient.prenom }} {{ rendez_vou.patient.nom }}</span>
                </div>
            </div>
        </div>
    </div>

    {# Actions #}
    <div class="detail-card">
        <h2 class="detail-section-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
            </svg>
            Actions
        </h2>

        {% if rendez_vou.etat.libelle == 'demandé' %}
            <div class="action-buttons">
                {% if is_granted('ROLE_PATIENT') %}
                    <a href="{{ path('app_mes_rendez_vous_edit', {id: rendez_vou.id}) }}" class="btn btn-warning btn-action">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                        </svg>
                        Modifier le rendez-vous
                    </a>
                    <button type="button" class="btn btn-danger btn-action" onclick="openModal('cancel-confirm-{{ rendez_vou.id }}')">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="15" y1="9" x2="9" y2="15"></line>
                            <line x1="9" y1="9" x2="15" y2="15"></line>
                        </svg>
                        Annuler le rendez-vous
                    </button>
                {% endif %}
                {% if is_granted('ROLE_ASSISTANT') or is_granted('ROLE_MEDECIN') %}
                    <form method="post" action="{{ path('app_rendez_vous_change_etat', {'id': rendez_vou.id}) }}" style="display: inline;">
                        <input type="hidden" name="etat" value="2">
                        <input type="hidden" name="_token" value="{{ csrf_token('change_etat' ~ rendez_vou.id) }}">
                        <button class="btn btn-success btn-action" type="submit">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                            Confirmer
                        </button>
                    </form>
                    <form method="post" action="{{ path('app_rendez_vous_change_etat', {'id': rendez_vou.id}) }}" style="display: inline;">
                        <input type="hidden" name="etat" value="4">
                        <input type="hidden" name="_token" value="{{ csrf_token('change_etat' ~ rendez_vou.id) }}">
                        <button class="btn btn-danger btn-action" type="submit">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="18" y1="6" x2="6" y2="18"></line>
                                <line x1="6" y1="6" x2="18" y2="18"></line>
                            </svg>
                            Refuser
                        </button>
                    </form>
                {% endif %}
            </div>
        {% elseif rendez_vou.etat.libelle == 'confirmé' %}
            <div class="status-message status-message-success">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
                <div>
                    <strong>Rendez-vous confirme</strong>
                    <p>{% if is_granted('ROLE_PATIENT') %}Votre rendez-vous a ete confirme par le cabinet medical.{% else %}Ce rendez-vous est confirme.{% endif %}</p>
                </div>
            </div>
            <div class="action-buttons" style="margin-top: 16px;">
                {% if is_granted('ROLE_PATIENT') %}
                    <button type="button" class="btn btn-danger btn-action" onclick="openModal('cancel-confirm-{{ rendez_vou.id }}')">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="15" y1="9" x2="9" y2="15"></line>
                            <line x1="9" y1="9" x2="15" y2="15"></line>
                        </svg>
                        Annuler le rendez-vous
                    </button>
                {% endif %}
                {% if is_granted('ROLE_ASSISTANT') or is_granted('ROLE_MEDECIN') %}
                    <form method="post" action="{{ path('app_rendez_vous_change_etat', {'id': rendez_vou.id}) }}" style="display: inline;">
                        <input type="hidden" name="etat" value="5">
                        <input type="hidden" name="_token" value="{{ csrf_token('change_etat' ~ rendez_vou.id) }}">
                        <button class="btn btn-primary btn-action" type="submit">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                <polyline points="22 4 12 14.01 9 11.01"></polyline>
                            </svg>
                            Marquer comme realise
                        </button>
                    </form>
                {% endif %}
            </div>
        {% elseif rendez_vou.etat.libelle == 'annulé' %}
            <div class="status-message status-message-danger">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="15" y1="9" x2="9" y2="15"></line>
                    <line x1="9" y1="9" x2="15" y2="15"></line>
                </svg>
                <div>
                    <strong>Rendez-vous annule</strong>
                    <p>Ce rendez-vous a ete annule.</p>
                </div>
            </div>
        {% elseif rendez_vou.etat.libelle == 'refusé' %}
            <div class="status-message status-message-danger">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
                <div>
                    <strong>Rendez-vous refuse</strong>
                    <p>Ce rendez-vous a ete refuse par le cabinet medical.</p>
                </div>
            </div>
        {% elseif rendez_vou.etat.libelle == 'réalisé' %}
            <div class="status-message status-message-info">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
                <div>
                    <strong>Rendez-vous realise</strong>
                    <p>Ce rendez-vous a bien ete effectue.</p>
                </div>
            </div>
        {% endif %}
    </div>

    {# Retour #}
    <div style="margin-top: 24px;">
        <a href="{{ path('app_mes_rendez_vous') }}" class="btn btn-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
            Retour a mes rendez-vous
        </a>
    </div>
</div>

{# Modal de confirmation pour annulation #}
{% if rendez_vou.etat.libelle not in ['realise', 'annule', 'refuse'] %}
    {{ include('components/modal_confirm.html.twig', {
        id: 'cancel-confirm-' ~ rendez_vou.id,
        title: 'Annuler le rendez-vous',
        message: 'Etes-vous sur de vouloir annuler ce rendez-vous ? Cette action est irreversible.',
        confirm_label: 'Annuler le rendez-vous',
        cancel_label: 'Conserver',
        form_action: path('app_mes_rendez_vous_cancel', {id: rendez_vou.id})
    }) }}
{% endif %}

<style>
.breadcrumb-nav {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
    font-size: 0.9rem;
}

.breadcrumb-link {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
}

.breadcrumb-link:hover {
    color: var(--primary);
}

.breadcrumb-sep {
    color: var(--border-light);
}

.breadcrumb-current {
    color: var(--text);
    font-weight: 500;
}

.detail-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 24px;
    flex-wrap: wrap;
}

.detail-header-content {
    display: flex;
    align-items: center;
    gap: 20px;
}

.detail-date-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    color: white;
    border-radius: 16px;
    flex-shrink: 0;
}

.detail-date-day {
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1;
}

.detail-date-month {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    opacity: 0.9;
}

.detail-title h1 {
    margin: 0 0 4px;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
}

.detail-time {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0;
    color: var(--text-muted);
    font-size: 0.95rem;
}

.status-badge-lg {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 24px;
    font-size: 0.95rem;
    font-weight: 600;
}

.status-pending {
    background: rgba(99, 102, 241, 0.1);
    color: var(--primary);
}

.status-success {
    background: rgba(16, 185, 129, 0.1);
    color: var(--success);
}

.status-danger {
    background: rgba(239, 68, 68, 0.1);
    color: var(--danger);
}

.status-info {
    background: rgba(23, 162, 184, 0.1);
    color: var(--info);
}

.detail-card {
    background: white;
    border: 1px solid var(--border-light);
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 16px;
    box-shadow: var(--shadow-sm);
}

.detail-section-title {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 20px;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
}

.detail-section-title svg {
    color: var(--primary);
}

.detail-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 16px;
}

.detail-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px;
    background: var(--bg-light);
    border-radius: 12px;
}

.detail-item-icon {
    width: 44px;
    height: 44px;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(168, 85, 247, 0.1) 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    flex-shrink: 0;
}

.detail-item-icon-medecin {
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(16, 185, 129, 0.05) 100%);
    color: var(--success);
}

.detail-item-icon-patient {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(168, 85, 247, 0.05) 100%);
    color: var(--primary);
}

.detail-item-content {
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.detail-item-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.detail-item-value {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
}

.action-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
}

.btn-action {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
}

.status-message {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px;
    border-radius: 12px;
}

.status-message svg {
    flex-shrink: 0;
    margin-top: 2px;
}

.status-message strong {
    display: block;
    margin-bottom: 4px;
}

.status-message p {
    margin: 0;
    font-size: 0.9rem;
    opacity: 0.9;
}

.status-message-success {
    background: rgba(16, 185, 129, 0.1);
    color: var(--success);
}

.status-message-danger {
    background: rgba(239, 68, 68, 0.1);
    color: var(--danger);
}

.status-message-info {
    background: rgba(23, 162, 184, 0.1);
    color: var(--info);
}

@media (max-width: 640px) {
    .detail-header {
        flex-direction: column;
        align-items: flex-start;
    }

    .detail-header-content {
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
    }

    .detail-date-badge {
        width: 100%;
        flex-direction: row;
        gap: 12px;
        height: auto;
        padding: 16px;
    }

    .detail-grid {
        grid-template-columns: 1fr;
    }

    .action-buttons {
        flex-direction: column;
    }

    .btn-action {
        width: 100%;
        justify-content: center;
    }
}

/* ===== DARK MODE STYLES ===== */
[data-theme="dark"] .detail-card {
    background: #1e293b;
    border-color: #334155;
}

[data-theme="dark"] .detail-header {
    border-bottom-color: #334155;
}

[data-theme="dark"] .detail-date-badge {
    background: linear-gradient(135deg, #6366f1 0%, #14b8a6 100%);
}

[data-theme="dark"] .detail-title h1 {
    color: #f1f5f9;
}

[data-theme="dark"] .detail-time {
    color: #94a3b8;
}

[data-theme="dark"] .detail-time svg {
    color: #818cf8;
}

[data-theme="dark"] .status-badge-pending {
    background: linear-gradient(135deg, rgba(129, 140, 248, 0.15) 0%, rgba(167, 139, 250, 0.1) 100%);
    color: #a5b4fc;
    border-color: rgba(129, 140, 248, 0.3);
}

[data-theme="dark"] .status-badge-success {
    background: linear-gradient(135deg, rgba(52, 211, 153, 0.15) 0%, rgba(110, 231, 183, 0.1) 100%);
