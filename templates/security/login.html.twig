{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div class="login-page">
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <div class="login-logo">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                </div>
                <h1>Bienvenue</h1>
                <p class="login-subtitle">Connectez-vous pour accéder à votre espace</p>
            </div>

            {% if app.user %}
                <div class="alert alert-info">
                    <p>Vous êtes déjà connecté en tant que <strong>{{ app.user.userIdentifier }}</strong>.</p>
                    <a href="{{ path('homepage') }}" class="btn btn-primary">
                        Retour à l'accueil
                    </a>
                </div>
            {% else %}
                <form method="post" data-turbo="false" class="login-form">
                    {% if error %}
                        <div class="alert alert-danger">
                            <strong>Erreur de connexion</strong>
                            <p>{{ error.messageKey|trans(error.messageData, 'security') }}</p>
                        </div>
                    {% endif %}

                    <fieldset>
                        <legend class="visually-hidden">Informations de connexion</legend>

                        <div class="form-group">
                            <label for="inputEmail">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                                    <polyline points="22,6 12,13 2,6"></polyline>
                                </svg>
                                Adresse e-mail
                            </label>
                            <input type="email"
                                   value="{{ last_username }}"
                                   name="_username"
                                   id="inputEmail"
                                   class="form-control"
                                   placeholder="votre.email@exemple.com"
                                   required
                                   autofocus>
                        </div>

                        <div class="form-group">
                            <label for="inputPassword">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                </svg>
                                Mot de passe
                            </label>
                            <input type="password"
                                   name="_password"
                                   id="inputPassword"
                                   class="form-control"
                                   placeholder="••••••••"
                                   required>
                        </div>

                        <div class="remember-row">
                            <label class="checkbox-label">
                                <input type="checkbox" name="_remember_me" id="remember_me">
                                <span class="checkmark"></span>
                                <span>Se souvenir de moi</span>
                            </label>
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    </fieldset>

                    <button class="btn btn-primary btn-lg btn-login" type="submit">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
                            <polyline points="10 17 15 12 10 7"></polyline>
                            <line x1="15" y1="12" x2="3" y2="12"></line>
                        </svg>
                        Se connecter
                    </button>
                </form>

                <div class="login-footer">
                    <p>
                        Pas encore de compte ?
                        <a href="{{ path('app_register') }}">Créer un compte</a>
                    </p>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<style>
.login-page {
    min-height: calc(100vh - 72px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    background: transparent;
}

.login-container {
    width: 100%;
    max-width: 440px;
}

.login-card {
    background: var(--card);
    border-radius: 24px;
    padding: 48px 40px;
    box-shadow: var(--shadow-xl);
    border: 1px solid var(--border-light);
}

.login-header {
    text-align: center;
    margin-bottom: 36px;
}

.login-logo {
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, #4f46e5 0%, #0d9488 100%);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    margin: 0 auto 20px;
    box-shadow: 0 8px 24px rgba(79, 70, 229, 0.3);
}

.login-header h1 {
    margin: 0 0 8px;
    font-size: 1.875rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--text) 0%, var(--primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.login-subtitle {
    margin: 0;
    color: var(--muted);
    font-size: 1rem;
}

.login-form {
    background: transparent;
    padding: 0;
    box-shadow: none;
}

.login-form fieldset {
    border: none;
    padding: 0;
    margin: 0;
}

.login-form .form-group {
    margin-bottom: 24px;
}

.login-form label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 10px;
}

.login-form label svg {
    color: var(--primary);
}

.login-form .form-control {
    padding: 14px 18px;
    border: 2px solid var(--border-light);
    border-radius: 14px;
    font-size: 1rem;
    transition: all 0.2s;
    background: var(--bg-light);
    color: var(--text);
}

.login-form .form-control:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 4px var(--primary-50);
}

.login-form .form-control::placeholder {
    color: var(--text-muted);
}

.remember-row {
    margin-bottom: 28px;
}

.checkbox-label {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    font-weight: 500;
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.checkbox-label input[type="checkbox"] {
    width: 20px;
    height: 20px;
    accent-color: var(--primary);
    border-radius: 6px;
}

.btn-login {
    width: 100%;
    padding: 16px 24px;
    border-radius: 14px;
    font-size: 1.05rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: linear-gradient(135deg, #4f46e5 0%, #4338ca 100%);
    box-shadow: 0 8px 24px rgba(79, 70, 229, 0.3);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-login:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(79, 70, 229, 0.4);
}

.btn-login:active {
    transform: translateY(0);
}

.login-footer {
    margin-top: 28px;
    text-align: center;
    padding-top: 24px;
    border-top: 1px solid var(--border-light);
}

.login-footer p {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
}

.login-footer a {
    color: var(--primary);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
}

.login-footer a:hover {
    color: var(--primary-dark);
    text-decoration: underline;
}

@media (max-width: 480px) {
    .login-card {
        padding: 36px 24px;
        border-radius: 20px;
    }
    
    .login-logo {
        width: 56px;
        height: 56px;
        border-radius: 16px;
    }
    
    .login-header h1 {
        font-size: 1.5rem;
    }
}

/* ===== DARK MODE STYLES ===== */
[data-theme="dark"] .login-card {
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    border-color: #334155;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.4);
}

[data-theme="dark"] .login-logo {
    background: linear-gradient(135deg, #6366f1 0%, #14b8a6 100%);
    box-shadow: 0 8px 24px rgba(99, 102, 241, 0.35);
}

[data-theme="dark"] .login-header h1 {
    background: linear-gradient(135deg, #f1f5f9 0%, #818cf8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

[data-theme="dark"] .login-header p {
    color: #94a3b8;
}

[data-theme="dark"] .form-group label {
    color: #cbd5e1;
}

[data-theme="dark"] .form-input,
[data-theme="dark"] .login-form .form-control {
    background: #0f172a;
    border-color: #334155;
    color: #f1f5f9;
}

[data-theme="dark"] .form-input:hover,
[data-theme="dark"] .login-form .form-control:hover {
    border-color: #475569;
}

[data-theme="dark"] .form-input:focus,
[data-theme="dark"] .login-form .form-control:focus {
    border-color: #818cf8;
    box-shadow: 0 0 0 4px rgba(129, 140, 248, 0.15);
}

[data-theme="dark"] .form-input::placeholder,
[data-theme="dark"] .login-form .form-control::placeholder {
    color: #64748b;
}

[data-theme="dark"] .remember-me label {
    color: #94a3b8;
}

[data-theme="dark"] .register-link {
    color: #94a3b8;
}

[data-theme="dark"] .register-link a {
    color: #818cf8;
}

[data-theme="dark"] .register-link a:hover {
    color: #a5b4fc;
}
</style>
{% endblock %}
