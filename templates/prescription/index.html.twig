{% extends 'base.html.twig' %}

{% block title %}Prescription index{% endblock %}

{% block body %}
    <h1>Prescription index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Quantite</th>
                <th>NombrePrise</th>
                <th>Duree</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for prescription in prescriptions %}
            <tr>
                <td>{{ prescription.id }}</td>
                <td>{{ prescription.quantite }}</td>
                <td>{{ prescription.nombrePrise }}</td>
                <td>{{ prescription.dureeEnJours ? (prescription.dureeEnJours|number_format(2, ',', ' ')) ~ ' jours' : '' }}</td>
                <td>
                    <a href="{{ path('app_prescription_show', {'id': prescription.id}) }}">show</a>
                    <a href="{{ path('app_prescription_edit', {'id': prescription.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <p>La creation de prescription se fait depuis un rendez-vous.</p>
{% endblock %}
